meta {
  name: Update Listing
  type: http
  seq: 9
}

patch {
  url: {{base_url}}/api/v1/listings/{{listing_id}}/
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "price": "4300.00",
    "quantity": "95.00"
  }
}

script:pre-request {
  const token = bru.getEnvVar("access_token");
  if (!token) {
    throw new Error("Missing access_token. Run Auth > Login first.");
  }
  
  req.setHeader("Authorization", `Bearer ${token}`);
}
