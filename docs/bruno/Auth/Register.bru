meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/v1/auth/register
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "username": "{{user_name}}",
    "email": "{{user_email}}",
    "password": "{{user_password}}",
    "first_name": "{{user_first_name}}",
    "last_name": "{{user_last_name}}",
    "role": "{{user_role}}",
    "phone_number": "{{user_phone_number}}",
    "organization": "{{user_organization}}"
  }
}
