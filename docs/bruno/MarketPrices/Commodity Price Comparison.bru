meta {
  name: Commodity Price Comparison
  type: http
  seq: 8
}

get {
  url: {{base_url}}/api/v1/commodities/{{commodity_id}}/price-comparison
  body: none
  auth: none
}

params:query {
  price_date: 
}

script:pre-request {
  const token = bru.getEnvVar("access_token");
  if (!token) {
    throw new Error("Missing access_token. Run Auth > Login first.");
  }
  
  req.setHeader("Authorization", `Bearer ${token}`);
}
