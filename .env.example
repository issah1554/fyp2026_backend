SECRET_KEY=change-this-secret-key
DEBUG=false
ALLOWED_HOSTS=127.0.0.1,localhost,kolinki.databenki.co.tz
CORS_ALLOWED_ORIGINS=https://fyp2026-web.vercel.app
CSRF_TRUSTED_ORIGINS=https://fyp2026-web.vercel.app,https://kolinki.databenki.co.tz
STATIC_ROOT=staticfiles

DB_ENGINE=django.db.backends.postgresql
DB_NAME=fyp2026_backend
DB_USER=postgres
DB_PASSWORD=change-this-password
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=60

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=Smart Market <your-email@example.com>
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-smtp-username
EMAIL_HOST_PASSWORD=your-smtp-password
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
